# LLM Configuration (Required)
FAST_MODEL_API_KEY=your-api-key
FAST_MODEL_ENDPOINT=https://api.openai.com/v1
FAST_MODEL_NAME=gpt-3.5-turbo

STRONG_MODEL_API_KEY=your-api-key
STRONG_MODEL_ENDPOINT=https://api.openai.com/v1
STRONG_MODEL_NAME=gpt-4

# Server Configuration (Optional, has defaults)
HOST=127.0.0.1
PORT=8000
AUTO_OPEN_BROWSER=true

# Database (Optional, SQLite auto-created)
# DATABASE_URL=sqlite:///./backend/data/council.db

# Session Configuration
SESSION_TTL=86400
MAX_DEBATE_ROUNDS=3

# Mock LLM for Development (set to true to use mock responses)
MOCK_LLM=false
